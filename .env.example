# Copy this file to .env and replace the placeholder values with your real local secrets.

SECRET_KEY=replace-with-a-long-random-secret

# Authentication storage
AUTH_DB_FILE=app/data/users.db
PUBLIC_BASE_URL=https://schwinn.example.com

# SMTP password reset settings
SMTP_NAME=your-email@me.com
SMTP_PASSWORD=your-app-password
SMTP_HOST=smtp.mail.me.com
SMTP_SECURE=tls
SMTP_PORT=587
SMTP_AUTHTYPE=LOGIN
MAIL_FROM_ADDRESS=your-sender@icloud.com

# Optional app settings
PASSWORD_RESET_MAX_AGE_SECONDS=3600
SESSION_COOKIE_SECURE=false
